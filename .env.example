# Database
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/job_scheduler
TYPEORM_SYNC=true

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Worker behaviour
SCHEDULER_ALGORITHM=heap          # heap | timing_wheel
DISPATCH_POLL_INTERVAL_MS=500
DISPATCH_CANDIDATE_LIMIT=200
WORKER_CONCURRENCY=4
STALE_LOCK_MS=60000

# Retries
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=5
BACKOFF_JITTER_RATIO=0.2

# Starvation prevention
AGING_THRESHOLD_SECONDS=60

# DLQ
DLQ_ALERT_THRESHOLD=10

# Simulated failure rate for demo handlers (0–1)
HANDLER_FAILURE_RATE=0.1
